# BRASALLIS HUB - GIT IGNORE (Security First)

# Configuração e Segredos
.env
.env.*
!.env.example
/includes/config.local.php
/config/*.local.php
session_data/

# Dependências
/vendor/
/node_modules/
package-lock.json
composer.lock

# Logs e Cache
/logs/*.log
*.log
*.cache
.phpunit.result.cache

# Base de Dados & Dumps (Segurança Crítica)
/database/data/
*.sql
*.sql.sql
*.db
*.sqlite
/database/*.sql
db_structure.json

# Resíduos de Debug e Testes
debug_*.php
check_*.php
test_*.php
temp_*.php
tmp_*.php
full_scan.php
multi_scan.php
*.txt
*.html
!README.md
!composer.json

# Uploads e Arquivos de Usuário
/uploads/
/public/uploads/
*.pdf
*.jpg
*.png
!assets/img/*.png
!assets/img/*.jpg
!assets/img/*.svg

# Sistema Operacional
.DS_Store
Thumbs.db
.idea/
.vscode/

# Build & Deploy
/dist/
/build/
deploy.bat
Procfile
Dockerfile
docker-compose.yml
docker-compose.prod.yml
